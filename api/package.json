{
  "name": "productgen-api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint src",
    "format": "prettier --write src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "openapi:export": "tsx src/docs/export-openapi.ts ../docs/static/openapi/productgen.json",
    "openapi:check": "tsx scripts/check-openapi-sync.ts",
    "db:schema": "tsx scripts/apply-schema.ts",
    "db:migrate": "tsx scripts/apply-schema.ts --skip-schema",
    "db:seed": "tsx scripts/apply-schema.ts --skip-schema --seed",
    "jwt:keys": "tsx scripts/generate-jwt-keys.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/sensible": "^6.0.0",
    "@fastify/swagger": "^9.7.0",
    "@sentry/node": "^10.53.1",
    "argon2": "^0.44.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.0",
    "jose": "^5.9.6",
    "pg": "^8.13.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^10.22.0",
    "@types/node": "^20.17.6",
    "@types/pg": "^8.11.10",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vitest": "^2.1.0"
  }
}
