# Banco de dados (Postgres)
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/productgen

# Chaves RS256 para assinar/verificar JWTs.
# Gere com: openssl genrsa -out jwt-private.pem 2048 && openssl rsa -in jwt-private.pem -pubout -out jwt-public.pem
# Em .env local, use PEM com quebras escapadas como \n.
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\ntroque-pela-chave-privada\n-----END PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\ntroque-pela-chave-publica\n-----END PUBLIC KEY-----"

# Segredo para assinar cookies — gere com: openssl rand -hex 64
COOKIE_SECRET=troque-por-outro-segredo-longo-aqui

# Ambiente
NODE_ENV=development

# Porta onde a API vai rodar
PORT=3002

# Origem do frontend autorizada pelo CORS
CORS_ORIGIN=http://localhost:3000

# Nível de log: fatal | error | warn | info | debug | trace
LOG_LEVEL=debug
