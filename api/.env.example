# Banco de dados (Postgres)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/productgen

# Segredo para assinar os JWTs — gere com: openssl rand -hex 64
JWT_SECRET=troque-por-um-segredo-longo-aqui

# Ambiente
NODE_ENV=development

# Porta onde a API vai rodar
PORT=3000

# Nível de log: fatal | error | warn | info | debug | trace
LOG_LEVEL=debug
