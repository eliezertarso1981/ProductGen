# Banco de dados (Postgres)
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/productgen

# Chaves RS256 para assinar/verificar JWTs.
# Gere com: openssl genrsa -out jwt-private.pem 2048 && openssl rsa -in jwt-private.pem -pubout -out jwt-public.pem
# Em .env local, use PEM com quebras escapadas como \n.
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\ntroque-pela-chave-privada\n-----END PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\ntroque-pela-chave-publica\n-----END PUBLIC KEY-----"

# Segredo para assinar cookies — gere com: openssl rand -hex 64
COOKIE_SECRET=troque-por-outro-segredo-longo-aqui

# Ambiente
NODE_ENV=development

# Porta onde a API vai rodar
PORT=3002

# Origem do frontend autorizada pelo CORS (várias origens separadas por vírgula)
CORS_ORIGIN=http://localhost:3000

# Cookies entre domínios diferentes (Railway: front e API em URLs distintas)
# Use `none` em produção com HTTPS quando web e API não compartilham o mesmo host.
COOKIE_SAME_SITE=lax

# Nível de log: fatal | error | warn | info | debug | trace
LOG_LEVEL=debug

# Sentry (opcional) — erros em produção: https://sentry.io
# SENTRY_DSN=https://...@....ingest.sentry.io/...
# SENTRY_ENVIRONMENT=production

# --- Railway (serviço API, root directory = api) ---
# DATABASE_URL = referência do plugin Postgres
# PORT = injetado pela Railway (não defina manualmente)
# NODE_ENV=production
# CORS_ORIGIN=https://seu-front.up.railway.app
# COOKIE_SAME_SITE=none
# JWT_* e COOKIE_SECRET = secrets no painel Railway
