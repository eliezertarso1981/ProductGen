# URL pública da API (definida no BUILD do Next.js).
NEXT_PUBLIC_PRODUCTGEN_API_URL=http://localhost:3002

# Sentry (opcional) — mesmo DSN no client; crie projeto em https://sentry.io
# NEXT_PUBLIC_SENTRY_DSN=https://...@....ingest.sentry.io/...
# NEXT_PUBLIC_SENTRY_ENVIRONMENT=production

# --- Railway (serviço Web, root directory = web) ---
# NEXT_PUBLIC_PRODUCTGEN_API_URL=https://sua-api.up.railway.app
# Após alterar esta variável, faça redeploy/rebuild do serviço web.
